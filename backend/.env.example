# Hack Orbit — Backend environment variables
# Copy to .env and fill in values

# Anthropic API key — used by /api/copilot and /api/incident-report
# If missing, the deterministic fallback is used (demo still works without this)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override which Claude model to use (default: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6
